{
  "name": "devtrack-api",
  "version": "1.0.0",
  "description": "Production-ready Express.js API scaffold with TypeScript",
  "private": true,
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/server.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/worker.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "lint": "eslint",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p tsconfig.json",
    "format": "prettier --write \"**/*.{ts,js,json}\"",
    "postinstall": "prisma generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@notionhq/client": "^5.2.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "better-auth": "^1.5.4",
    "bullmq": "^5.71.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "nodemailer": "^8.0.2",
    "pg": "^8.20.0",
    "winston": "^3.17.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "prisma": "^7.4.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
